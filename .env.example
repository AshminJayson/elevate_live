# BitForge configuration — the single source of config.
# Copy to .env and edit:  cp .env.example .env
# Exported environment variables override values set here.
#
# NOTE: this root .env is your real host config and is git-ignored.
# It is NOT the same as source/.env, which is content broadcast
# verbatim to viewers — never put a real token there.

# Host auth token (REQUIRED). Gates the broadcaster's /ws/host
# connection. Anyone with it can drive the broadcast; keep it secret.
BITFORGE_TOKEN=change-me

# Optional reserved ngrok domain; leave blank for a random ephemeral URL.
BITFORGE_NGROK_DOMAIN=

# ngrok account credential, from https://dashboard.ngrok.com/get-started/your-authtoken
# Authenticates the ngrok agent (passed via NGROK_AUTHTOKEN). This is NOT the
# host token above. Leave blank if you've run `ngrok config add-authtoken`.
BITFORGE_NGROK_AUTHTOKEN=

# Directory broadcast to viewers.
BITFORGE_SOURCE_DIR=./source

# Viewer page title.
BITFORGE_TITLE=FastAPI Live

# Patterns hidden from BOTH the file tree and /file, as a JSON array.
# Defaults exclude only noise/danger; dotfiles like source/.env are SHOWN.
BITFORGE_IGNORE=[".git/", ".venv/", "venv/", "__pycache__/", "node_modules/", "*.pyc"]

# Shared tmux session name (host, ttyd, runner).
BITFORGE_TMUX_SESSION=class

# Fixed terminal size streamed to viewers.
BITFORGE_COLS=100
BITFORGE_ROWS=30

# Detailed append-mode log file (relative to launch dir, or absolute). The
# console stays quiet — uvicorn/ttyd/ngrok/broadcaster output and per-connection
# detail all land here; the console shows only the periodic viewers-online line.
BITFORGE_LOG_FILE=bitforge.log

# Seconds between console heartbeat lines reporting how many viewers are online.
BITFORGE_HEARTBEAT_SECONDS=10
