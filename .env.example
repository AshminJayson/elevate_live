# LiveClass configuration — the single source of config.
# Copy to .env and edit:  cp .env.example .env
# Exported environment variables override values set here.
#
# NOTE: this root .env is your real teacher config and is git-ignored.
# It is NOT the same as lesson/.env, which is teaching content broadcast
# verbatim to students — never put a real token there.

# Teacher auth token (REQUIRED). Gates the broadcaster's /ws/teacher
# connection. Anyone with it can drive the broadcast; keep it secret.
LIVECLASS_TOKEN=change-me

# Optional reserved ngrok domain; leave blank for a random ephemeral URL.
LIVECLASS_NGROK_DOMAIN=

# ngrok account credential, from https://dashboard.ngrok.com/get-started/your-authtoken
# Authenticates the ngrok agent (passed via NGROK_AUTHTOKEN). This is NOT the
# teacher token above. Leave blank if you've run `ngrok config add-authtoken`.
LIVECLASS_NGROK_AUTHTOKEN=

# Directory broadcast to students.
LIVECLASS_LESSON_DIR=./lesson

# Student page title.
LIVECLASS_TITLE=FastAPI Live

# Patterns hidden from BOTH the file tree and /file, as a JSON array.
# Defaults exclude only noise/danger; dotfiles like lesson/.env are SHOWN.
LIVECLASS_IGNORE=[".git/", ".venv/", "venv/", "__pycache__/", "node_modules/", "*.pyc"]

# Shared tmux session name (teacher, ttyd, runner).
LIVECLASS_TMUX_SESSION=class

# Fixed terminal size streamed to students.
LIVECLASS_COLS=100
LIVECLASS_ROWS=30
